# Copy this file to .env.local and fill in your values

# Required: Google Gemini API key — free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Optional: Path to coral binary if not in PATH
# Windows example: CORAL_BIN=C:\Users\YourName\AppData\Local\coral\coral.exe
# Default: "coral" (assumes it's in PATH)
CORAL_BIN=coral
